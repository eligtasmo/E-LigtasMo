{
  "name": "tailadmin-react",
  "private": true,
  "version": "2.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:clean": "node scripts/free-ports.cjs && npm run dev",
    "dev:clean:both": "node scripts/free-ports.cjs && npm run dev:both",
    "dev:force5173": "node scripts/free-ports.cjs && vite --host --port 5173 --strictPort",
    "dev:web": "concurrently \"npm run dev\" \"npm run server\" \"npm run proxy\"",
    "dev:mobile": "node scripts/start-mobile.cjs",
    "dev:mobile:tunnel": "node scripts/start-mobile.cjs --tunnel",
    "build": "vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "json-server --watch db.json --port 3001",
    "proxy": "node server.cjs",
    "dev:both": "node scripts/dev-both.cjs",
    "dev:both:tunnel": "node scripts/dev-both.cjs --tunnel"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.15",
    "@fullcalendar/daygrid": "^6.1.15",
    "@fullcalendar/interaction": "^6.1.15",
    "@fullcalendar/list": "^6.1.15",
    "@fullcalendar/react": "^6.1.15",
    "@fullcalendar/timegrid": "^6.1.15",
    "@react-google-maps/api": "^2.20.6",
    "@react-jvectormap/core": "^1.0.4",
    "@react-jvectormap/world": "^1.1.2",
    "@turf/turf": "^7.2.0",
    "@types/mapbox-gl": "^3.4.1",
    "apexcharts": "^4.1.0",
    "axios": "^1.12.2",
    "chart.js": "^4.5.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "flatpickr": "^4.6.13",
    "framer-motion": "^12.23.18",
    "html2canvas": "^1.4.1",
    "json-server": "^1.0.0-beta.3",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lodash": "^4.17.21",
    "mapbox-gl": "^2.15.0",
    "node-fetch": "^2.7.0",
    "react": "^19.0.0",
    "react-apexcharts": "^1.7.0",
    "react-chartjs-2": "^5.3.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.5",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.63.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-map-gl": "^7.1.7",
    "react-responsive": "^10.0.1",
    "react-router": "^7.1.5",
    "react-router-dom": "^7.6.0",
    "swiper": "^11.2.3",
    "tailwind-merge": "^3.0.1",
    "three": "^0.160.0",
    "uuid": "^13.0.0",
    "workbox-webpack-plugin": "^7.3.0",
    "workbox-window": "^7.3.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@tailwindcss/postcss": "^4.0.8",
    "@types/leaflet": "^1.9.18",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/react-responsive": "^8.0.8",
    "@types/react-router-dom": "^5.3.3",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "postcss": "^8.5.2",
    "tailwindcss": "^4.0.8",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.1.0",
    "vite-plugin-svgr": "^4.3.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11",
    "Chrome >= 58",
    "Firefox >= 57",
    "Safari >= 11",
    "Edge >= 16",
    "Opera >= 45"
  ],
  "overrides": {
    "react-helmet-async": {
      "react": "^16.8.0 || ^17 || ^18 || ^19"
    },
    "@react-jvectormap/core": {
      "react": "^16.8.0 || ^17 || ^18 || ^19",
      "react-dom": "^16.8.0 || ^17 || ^18 || ^19"
    },
    "@react-jvectormap/world": {
      "react": "^16.8.0 || ^17 || ^18 || ^19",
      "react-dom": "^16.8.0 || ^17 || ^18 || ^19"
    }
  }
}
